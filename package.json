{
  "name": "@react-three/native",
  "version": "10.0.0",
  "description": "React Native bindings for @react-three/fiber",
  "keywords": [
    "react",
    "react-native",
    "expo",
    "three",
    "threejs",
    "fiber"
  ],
  "author": "Paul Henschel (https://github.com/drcmda)",
  "license": "MIT",
  "maintainers": [
    "Josh Ellis (https://github.com/joshuaellis)",
    "Cody Bennett (https://github.com/codyjasonbennett)",
    "Kris Baumgarter (https://github.com/krispya)"
  ],
  "bugs": {
    "url": "https://github.com/pmndrs/react-three-fiber/issues"
  },
  "homepage": "https://github.com/pmndrs/react-three-fiber#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/pmndrs/react-three-fiber.git"
  },
  "main": "dist/index.cjs.js",
  "module": "dist/index.esm.js",
  "react-native": "dist/index.cjs.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "react-native": "./dist/index.cjs.js",
      "types": "./dist/index.d.ts",
      "import": "./dist/index.esm.js",
      "require": "./dist/index.cjs.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "sideEffects": [
    "./dist/index.esm.js",
    "./dist/index.cjs.js",
    "./src/index.tsx"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "test": "jest",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "base64-js": "^1.5.1",
    "buffer": "^6.0.3",
    "its-fine": "^2.0.0",
    "jpeg-js": "^0.4.4",
    "upng-js": "^2.1.0"
  },
  "peerDependencies": {
    "@react-three/fiber": "^10.0.0",
    "expo": ">=43.0",
    "expo-asset": ">=8.4",
    "expo-file-system": ">=11.0",
    "expo-gl": ">=11.0",
    "react": "^19.0.0",
    "react-native": ">=0.78",
    "three": ">=0.181.2"
  },
  "devDependencies": {
    "@react-three/fiber": "10.0.0-alpha.2",
    "@react-three/test-renderer": "^11.0.0",
    "@types/jest": "^29.5.0",
    "@types/react": "^19.0.0",
    "@types/three": "^0.183.0",
    "expo-asset": "^55.0.0",
    "expo-file-system": "^55.0.0",
    "expo-gl": "^55.0.0",
    "jest": "^29.7.0",
    "react": "^19.0.0",
    "react-native": "^0.78.0",
    "react-nil": "^2.0.0",
    "three": "^0.183.0",
    "ts-jest": "^29.2.0",
    "ts-node": "^10.9.2",
    "tsup": "^8.3.0",
    "typescript": "^5.7.0"
  },
  "peerDependenciesMeta": {
    "expo": {
      "optional": true
    },
    "expo-asset": {
      "optional": true
    },
    "expo-file-system": {
      "optional": true
    },
    "expo-gl": {
      "optional": true
    }
  }
}
